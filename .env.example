# ============================================================
# Enterprise MCP Server — Environment Configuration
# Copy this file to .env and fill in your credentials
# ============================================================

# ---- Jira Cloud --------------------------------------------------------- #
JIRA_BASE_URL=https://yourcompany.atlassian.net
JIRA_EMAIL=you@yourcompany.com
JIRA_API_TOKEN=your_jira_api_token_here

# ---- GitHub -------------------------------------------------------------- #
GITHUB_TOKEN=ghp_your_github_personal_access_token
GITHUB_DEFAULT_OWNER=your-org-or-username

# ---- Confluence Cloud ---------------------------------------------------- #
CONFLUENCE_BASE_URL=https://yourcompany.atlassian.net
CONFLUENCE_EMAIL=you@yourcompany.com
CONFLUENCE_API_TOKEN=your_confluence_api_token_here

# ---- Slack --------------------------------------------------------------- #
SLACK_BOT_TOKEN=xoxb-your-slack-bot-token

# ---- PagerDuty ---------------------------------------------------------- #
PAGERDUTY_API_KEY=your_pagerduty_api_key
PAGERDUTY_FROM_EMAIL=you@yourcompany.com

# ---- Datadog ------------------------------------------------------------- #
DATADOG_API_KEY=your_datadog_api_key
DATADOG_APP_KEY=your_datadog_app_key
DATADOG_SITE=datadoghq.com

# ---- Redis --------------------------------------------------------------- #
REDIS_URL=redis://localhost:6379/0

# ---- Webhooks ------------------------------------------------------------ #
GITHUB_WEBHOOK_SECRET=your_github_webhook_secret
JIRA_WEBHOOK_SECRET=your_jira_webhook_secret
SLACK_SIGNING_SECRET=your_slack_signing_secret

# ---- OAuth --------------------------------------------------------------- #
GITHUB_CLIENT_ID=your_github_oauth_client_id
GITHUB_CLIENT_SECRET=your_github_oauth_client_secret

# ---- Multi-tenant ------------------------------------------------------- #
TENANT_CONFIG_PATH=

# ---- Server -------------------------------------------------------------- #
SERVER_NAME=enterprise-mcp
LOG_LEVEL=INFO
HEALTH_PORT=8080
WEBHOOK_PORT=8081
OTLP_ENDPOINT=
